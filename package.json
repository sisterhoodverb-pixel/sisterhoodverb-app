{
  "name": "sisterhoodverb-community",
  "version": "1.0.0",
  "private": true,
  "description": "Sisterhood(verb) Community iOS App",
  "scripts": {
    "build": "mkdir -p www && cp app.html www/index.html && cp manifest.json favicon.ico favicon-16.png favicon-32.png sw.js www/ && cp -r icons www/",
    "sync": "npm run build && npx cap sync",
    "open:ios": "npx cap open ios",
    "deploy:ios": "npm run sync && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.6.2",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/ios": "^7.6.2",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@revenuecat/purchases-capacitor": "^13.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.2"
  }
}
